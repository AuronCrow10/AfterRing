{
  "name": "voice-ai-intake",
  "version": "1.0.0",
  "description": "Multi-tenant Voice AI intake system with Twilio, OpenAI Realtime, Deepgram TTS, and Prisma",
  "main": "dist/index.js",
  "scripts": {
    "dev": "set NODE_ENV=development&& ts-node-dev --respawn --transpile-only --ignore-watch .next --ignore-watch dist --ignore-watch node_modules src/index.ts",
    "build": "next build && tsc -p tsconfig.server.json",
    "start": "node dist/index.js",
    "test:harness": "npm run build && node scripts/barge-in-harness.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@twilio/voice-sdk": "^2.18.2",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.0.0",
    "next": "^16.2.4",
    "nodemailer": "^6.9.14",
    "openai": "^4.73.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "^9.0.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.14.11",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "19.2.14",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "prisma": "^5.18.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
