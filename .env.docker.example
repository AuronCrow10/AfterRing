NODE_ENV=production
PORT=3000
APP_PORT=3000
LOG_LEVEL=info

POSTGRES_DB=voiceai
POSTGRES_USER=voiceai
POSTGRES_PASSWORD=replace-with-a-long-url-safe-password

PUBLIC_BASE_URL=https://your-domain.example

OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-mini

DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=
DEEPGRAM_TTS_ENCODING=mulaw
DEEPGRAM_TTS_SAMPLE_RATE=8000

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_CALLER_ID=
TWILIO_INBOUND_NUMBER=

JWT_SECRET=replace-with-at-least-32-random-characters
AUTH_COOKIE_NAME=voiceai_session

MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_SMTP_HOST=in-v3.mailjet.com
MAILJET_SMTP_PORT=587
MAIL_FROM_EMAIL=
MAIL_FROM_NAME=Voice AI Assistant
CONTACT_EMAIL=

INTAKE_DEFAULT_LOCALE=it-IT
ASSISTANT_TIMEZONE_LABEL=Europe/Rome
VAD_SILENCE_MS=300
PHONE_CHUNK_DEADLINE_MS=1500
PHONE_ENTRY_TIMEOUT_MS=2500
BARGE_IN_AVG_ABS_THRESHOLD=950
BARGE_IN_FRAMES_REQUIRED=3

OPENAI_INPUT_COST_PER_1K=0.0006
OPENAI_OUTPUT_COST_PER_1K=0.0024
DEEPGRAM_TTS_COST_PER_1K_CHARS=0
TWILIO_COST_PER_MINUTE=0
